# Optional LLM judge configuration for the `llm_rubric` grader.
# The llm_rubric grader is DISABLED by default; it only runs when a task's
# grader config sets `enabled: true`. None of these are required for the
# default (deterministic) eval path or for the test suite.

# Provider to use for the LLM judge: "mock" (default, no network), "openai", or "anthropic".
AGENT_EVAL_JUDGE_PROVIDER=mock

# Model name for the judge. Intentionally not defaulted to a paid model.
AGENT_EVAL_JUDGE_MODEL=

# API keys (only needed if you switch the provider away from "mock").
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
