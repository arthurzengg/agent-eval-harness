<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ suite.name }} — eval report</title>
<style>
  :root { --fg:#1b1f24; --muted:#57606a; --line:#e3e6ea; --ok:#1a7f37; --bad:#cf222e; --bg:#fff; }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
         color: #1b1f24; margin: 0; background: #f6f8fa; }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 24px; }
  h1 { margin: 0 0 4px; font-size: 22px; }
  h2 { margin: 28px 0 10px; font-size: 17px; border-bottom: 1px solid #e3e6ea; padding-bottom: 6px; }
  .muted { color: #57606a; }
  .cards { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 14px; }
  .card { background: #fff; border: 1px solid #e3e6ea; border-radius: 8px; padding: 12px 16px; min-width: 130px; }
  .card .k { font-size: 12px; color: #57606a; text-transform: uppercase; letter-spacing: .04em; }
  .card .v { font-size: 20px; font-weight: 600; margin-top: 4px; }
  table { border-collapse: collapse; width: 100%; background: #fff; border: 1px solid #e3e6ea; border-radius: 8px; overflow: hidden; }
  th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eef1f4; font-size: 14px; vertical-align: top; }
  th { background: #f6f8fa; font-weight: 600; }
  .pass { color: #1a7f37; font-weight: 600; }
  .fail { color: #cf222e; font-weight: 600; }
  .bar { height: 8px; border-radius: 4px; background: #eef1f4; overflow: hidden; min-width: 80px; }
  .bar > span { display: block; height: 100%; background: #1a7f37; }
  details { background: #fff; border: 1px solid #e3e6ea; border-radius: 8px; margin: 8px 0; padding: 6px 12px; }
  summary { cursor: pointer; font-weight: 600; }
  pre { background: #f6f8fa; border-radius: 6px; padding: 10px; overflow: auto; font-size: 12.5px; }
  .step { border-left: 3px solid #d0d7de; padding: 4px 10px; margin: 6px 0; }
  .step.assistant { border-color: #0969da; }
  .step.tool { border-color: #8250df; }
  .step.user { border-color: #57606a; }
  .role { font-size: 11px; text-transform: uppercase; color: #57606a; letter-spacing: .04em; }
  .timeline { display: flex; flex-wrap: wrap; gap: 6px; margin: 6px 0; }
  .chip { background: #ddf4ff; border: 1px solid #b6e3ff; color: #0969da; border-radius: 999px; padding: 2px 10px; font-size: 12px; }
  .reason { color: #cf222e; font-size: 13px; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin: 14px 0 4px;
             position: sticky; top: 0; background: #f6f8fa; padding: 8px 0; z-index: 5; }
  .btn { background: #fff; border: 1px solid #d0d7de; border-radius: 6px; padding: 4px 10px;
         font-size: 13px; cursor: pointer; color: #1b1f24; }
  .btn:hover { background: #f3f4f6; }
  .toolbar label { font-size: 13px; color: #1b1f24; display: inline-flex; gap: 5px; align-items: center; }
  .copy { border: 1px solid #d0d7de; background: #fff; border-radius: 6px; font-size: 11px;
          padding: 1px 7px; cursor: pointer; color: #57606a; margin-left: 6px; }
  .copy:hover { background: #f3f4f6; }
  .hidden { display: none !important; }
  .trial.pass-trial > summary::before { content: "✓ "; color: #1a7f37; }
  .trial.fail-trial > summary::before { content: "✗ "; color: #cf222e; }
</style>
</head>
<body>
<div class="wrap">
  <h1>{{ suite.name }}</h1>
  <div class="muted">{{ suite.id }} · v{{ suite.version }} · scoring: {{ scoring_mode }}</div>
  {% if suite.description %}<p class="muted">{{ suite.description }}</p>{% endif %}

  <div class="toolbar">
    <label><input type="checkbox" id="failOnly" onchange="applyFilter()" /> Show only failing trials</label>
    <button class="btn" onclick="setAllTrials(true)">Expand all trials</button>
    <button class="btn" onclick="setAllTrials(false)">Collapse all trials</button>
    <span class="muted" id="filterCount"></span>
  </div>

  <h2>Metrics</h2>
  <div class="cards">
    {% set m = metrics %}
    <div class="card"><div class="k">Tasks</div><div class="v">{{ m.total_tasks }}</div></div>
    <div class="card"><div class="k">Trials</div><div class="v">{{ m.total_trials }}</div></div>
    <div class="card"><div class="k">Pass rate</div><div class="v">{{ pct(m.pass_rate) }}</div></div>
    <div class="card"><div class="k">pass@{{ m.k_label() }}</div><div class="v">{{ pct(m.pass_at_k) }}</div></div>
    <div class="card"><div class="k">pass^{{ m.k_label() }}</div><div class="v">{{ pct(m.pass_caret_k) }}</div></div>
    {% if not m.consistent_k %}
    <div class="card"><div class="k">Trials / task</div><div class="v">mixed ({{ m.k_min }}..{{ m.k_max }})</div></div>
    {% endif %}
    <div class="card"><div class="k">Avg score</div><div class="v">{{ '%.3f'|format(m.avg_score) }}</div></div>
    <div class="card"><div class="k">Avg latency</div><div class="v">{{ '%.0f'|format(m.avg_latency_ms) }} ms</div></div>
    <div class="card"><div class="k">Error rate</div><div class="v">{{ pct(m.error_rate) }}</div></div>
    {% if m.total_tokens %}
    <div class="card"><div class="k">Avg tokens (in/out)</div><div class="v">{{ '%.0f'|format(m.avg_input_tokens) }} / {{ '%.0f'|format(m.avg_output_tokens) }}</div></div>
    <div class="card"><div class="k">Total tokens</div><div class="v">{{ '{:,}'.format(m.total_tokens) }}</div></div>
    {% endif %}
    {% if m.total_cost_usd %}
    <div class="card"><div class="k">Avg cost / trial</div><div class="v">${{ '%.4f'|format(m.avg_cost_usd) }}</div></div>
    <div class="card"><div class="k">Total cost</div><div class="v">${{ '%.4f'|format(m.total_cost_usd) }}</div></div>
    {% endif %}
  </div>

  {% if reliability|length > 1 %}
  <h2>Reliability curve</h2>
  <p class="muted">pass@k = at least one of k trials passes; pass^k = all k pass.
     At each k only tasks with at least k trials contribute.</p>
  <table>
    <tr><th>k</th><th>pass@k</th><th>pass^k</th><th>Tasks</th></tr>
    {% for p in reliability %}
    <tr><td>{{ p.k }}</td><td>{{ pct(p.pass_at_k) }}</td>
        <td>{{ pct(p.pass_caret_k) }}</td><td>{{ p.n_tasks }}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  {% if flaky %}
  <h2>Flaky tasks</h2>
  <p class="muted">Tasks that pass on some trials and fail on others (most split first).</p>
  <table>
    <tr><th>Task</th><th>Passed / Trials</th><th>Flakiness</th></tr>
    {% for f in flaky %}
    <tr><td><a href="#task-{{ f.task_id }}">{{ f.task_id }}</a></td>
        <td>{{ f.n_passed }} / {{ f.n_trials }}</td>
        <td>{{ '%.2f'|format(f.flakiness) }}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  <h2>Per-grader aggregation</h2>
  <table>
    <tr><th>Grader</th><th>Passed / Total</th><th>Pass rate</th><th></th></tr>
    {% for g in per_grader_detail %}
    <tr>
      <td>{{ g.type }}</td>
      <td>{{ g.passed }} / {{ g.total }}</td>
      <td>{{ pct(g.rate) }}</td>
      <td><div class="bar"><span style="width: {{ (g.rate * 100)|round }}%;
          {% if g.rate < 1.0 %}background:#bf8700{% endif %}"></span></div></td>
    </tr>
    {% endfor %}
  </table>

  <h2>Tasks</h2>
  <table>
    <tr><th>Task</th><th>Passed / Trials</th><th>Avg score</th>
        {% if metrics.total_tokens %}<th>Tokens</th>{% endif %}<th></th></tr>
    {% for tr in task_results %}
    <tr>
      <td><a href="#task-{{ tr.task_id }}">{{ tr.task_id }}</a>
          <button class="copy" data-copy="{{ tr.task_id }}" onclick="copyId(this)">copy id</button></td>
      <td>{{ tr.num_passed }} / {{ tr.num_trials }}</td>
      <td>{{ '%.3f'|format(tr.avg_score) }}</td>
      {% if metrics.total_tokens %}<td>{{ '{:,}'.format(task_tokens.get(tr.task_id, 0)) }}</td>{% endif %}
      <td><div class="bar"><span style="width: {{ (tr.pass_rate * 100)|round }}%"></span></div></td>
    </tr>
    {% endfor %}
  </table>

  {% for tr in task_results %}
  <h2 id="task-{{ tr.task_id }}">Task: {{ tr.task_id }}
    <button class="copy" data-copy="{{ tr.task_id }}" onclick="copyId(this)">copy id</button>
  </h2>
  {% for t in tr.trials %}
  {% set tokens = t.trial.transcript.total_tokens() %}
  <details class="trial {{ 'pass-trial' if t.passed else 'fail-trial' }}" data-pass="{{ '1' if t.passed else '0' }}">
    <summary>
      Trial {{ t.trial.index }} —
      {% if t.passed %}<span class="pass">PASS</span>{% else %}<span class="fail">FAIL</span>{% endif %}
      · score {{ '%.3f'|format(t.score) }} · {{ '%.0f'|format(t.trial.latency_ms) }} ms
      {% if tokens %}· {{ '{:,}'.format(tokens) }} tokens{% endif %}
    </summary>

    {% if t.trial.error %}<p class="reason">Trial error: {{ t.trial.error }}</p>{% endif %}

    <h4>Grader results</h4>
    <table>
      <tr><th>Grader</th><th>Score</th><th>Pass</th><th>Weight</th><th>Reason</th></tr>
      {% for gr in t.grader_results %}
      <tr>
        <td>{{ gr.grader_type }}{% if not gr.enabled %} <span class="muted">(disabled)</span>{% endif %}</td>
        <td>{{ '%.2f'|format(gr.score) }}</td>
        <td>{% if gr.passed %}<span class="pass">yes</span>{% else %}<span class="fail">no</span>{% endif %}</td>
        <td>{{ gr.weight }}</td>
        <td>{{ gr.reason }}</td>
      </tr>
      {% endfor %}
    </table>

    {% set tcalls = t.trial.transcript.tool_calls() %}
    {% if tcalls %}
    <h4>Tool-call timeline</h4>
    <div class="timeline">
      {% for call in tcalls %}<span class="chip">{{ loop.index }}. {{ call.name }}</span>{% endfor %}
    </div>
    {% endif %}

    <h4>Final output</h4>
    <pre>{{ t.trial.final_output }}</pre>

    <details class="transcript"{% if not t.passed %} open{% endif %}>
      <summary>Transcript ({{ t.trial.transcript.steps|length }} steps)</summary>
      {% for step in t.trial.transcript.steps %}
      <div class="step {{ step.role }}">
        <div class="role">{{ step.role }}</div>
        {% if step.content is not none %}<div>{{ step.content if step.content is string else tojson(step.content) }}</div>{% endif %}
        {% if step.tool_call %}<div class="muted">→ {{ step.tool_call.name }}({{ tojson(step.tool_call.arguments) }})</div>{% endif %}
        {% if step.tool_result %}<div class="muted">← {{ tojson(step.tool_result.content) }}</div>{% endif %}
        {% if step.error %}<div class="reason">{{ step.error }}</div>{% endif %}
      </div>
      {% endfor %}
    </details>

    <details><summary>Outcome JSON</summary><pre>{{ tojson(t.trial.outcome.state) }}</pre></details>
    <details><summary>Raw trial JSON</summary><pre>{{ tojson(t.model_dump(mode="json")) }}</pre></details>
  </details>
  {% endfor %}
  {% endfor %}

  <p class="muted" style="margin-top:32px">Generated by agent-eval-harness.</p>
</div>
<script>
  // Toggle every top-level trial open/closed.
  function setAllTrials(open) {
    document.querySelectorAll("details.trial").forEach(function (d) {
      if (!d.classList.contains("hidden")) d.open = open;
    });
  }
  // Show only failing trials (and hide now-empty task headings).
  function applyFilter() {
    var failOnly = document.getElementById("failOnly").checked;
    var hidden = 0, shown = 0;
    document.querySelectorAll("details.trial").forEach(function (d) {
      var hide = failOnly && d.dataset.pass === "1";
      d.classList.toggle("hidden", hide);
      hide ? hidden++ : shown++;
    });
    document.querySelectorAll("h2[id^='task-']").forEach(function (h) {
      var any = false, n = h.nextElementSibling;
      while (n && n.tagName === "DETAILS") {
        if (!n.classList.contains("hidden")) any = true;
        n = n.nextElementSibling;
      }
      h.classList.toggle("hidden", failOnly && !any);
    });
    var label = document.getElementById("filterCount");
    label.textContent = failOnly ? shown + " failing trial(s) shown, " + hidden + " hidden" : "";
  }
  // Copy a task id to the clipboard with brief button feedback.
  function copyId(btn) {
    var text = btn.dataset.copy, prev = btn.textContent;
    var done = function () { btn.textContent = "copied!"; setTimeout(function () { btn.textContent = prev; }, 1200); };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(done, done);
    } else {
      var ta = document.createElement("textarea");
      ta.value = text; document.body.appendChild(ta); ta.select();
      try { document.execCommand("copy"); } catch (e) {}
      document.body.removeChild(ta); done();
    }
  }
</script>
</body>
</html>
