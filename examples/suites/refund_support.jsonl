{"suite": {"id": "refund_support_jsonl", "name": "Refund support (JSONL)", "description": "Same checks as the YAML suite, authored one task per line."}, "defaults": {"trials": 2, "scoring": {"mode": "weighted", "pass_threshold": 0.8}}}
